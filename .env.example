# ============================================================
# Command Center — Configuration
# Most settings are configured via the setup wizard in the browser.
# ============================================================

# ── COMMAND CENTER AUTH (Set by installer) ────────────────
CC_PASSWORD=
CC_SESSION_SECRET=

# ── BRANDING (Configured via setup wizard) ────────────────
COMPANY_NAME=
ASSISTANT_NAME=
TAGLINE=
PRIMARY_COLOR_HUE=264
PRIMARY_COLOR_SAT=65
PRIMARY_COLOR_LIT=49

# ── AI (Configured via setup wizard) ─────────────────────
ANTHROPIC_API_KEY=

# ── TELEGRAM (Configured via setup wizard) ────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── INTEGRATIONS (Configured via setup wizard) ───────────
HEYGEN_API_KEY=
STRIPE_SECRET_KEY=
COMPOSIO_API_KEY=
# Composio connected-account ID for the Calendar Assistant (Google Calendar)
COMPOSIO_ACCOUNT_ID=
YOUTUBE_API_KEY=

# ── META / INSTAGRAM (Optional — for Ads Manager) ───────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# ── BRAND ASSETS ─────────────────────────────────────────
BRAND_ASSET_URL=

# ── LOCALIZATION ─────────────────────────────────────────
# Language for AI responses and UI messages (default: en)
LANGUAGE=
# Timezone for calendar and scheduling (default: system timezone or UTC)
TIMEZONE=
# Default niche for research tasks (default: empty — generic)
DEFAULT_NICHE=

# ── DAILY MARKET ANALYSIS PUBLISH (optional) ──────────────
# When both are set, the market-analysis part of each daily research run is
# POSTed to an external content channel (e.g. a membership/academy platform).
# Leave empty to disable. The endpoint should accept {title, body} JSON and the
# key via the x-ingest-key header.
MARKET_ANALYSIS_WEBHOOK_URL=
MARKET_ANALYSIS_WEBHOOK_KEY=

# ── INFRASTRUCTURE (Auto-set by installer) ────────────────
INSTALL_DIR=/opt/commandcenter
DASHBOARD_URL=http://localhost:3004
