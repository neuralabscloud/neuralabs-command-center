# ============================================================
# Trading Bot Platform — Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── BRANDING ────────────────────────────────────────────────
# Your company/platform name (shown in UI, Telegram, AI assistant)
COMPANY_NAME=MyTradingCo
ASSISTANT_NAME=Assistant
TAGLINE=Your Trading Platform

# HSL color values for primary brand color (default: purple)
PRIMARY_COLOR_HUE=264
PRIMARY_COLOR_SAT=65
PRIMARY_COLOR_LIT=49

# ── COMMAND CENTER AUTH (Required) ──────────────────────────
# Password to log into the web dashboard
CC_PASSWORD=
# Random string for session signing (auto-generated by installer)
CC_SESSION_SECRET=

# ── AI (Required) ──────────────────────────────────────────
# Anthropic Claude API key — required for AI assistant and agents
ANTHROPIC_API_KEY=

# ── FUNDING BOT — Hyperliquid (Required for bot operation) ──
FUNDING_BOT_PRIVATE_KEY=
FUNDING_BOT_WALLET_ADDRESS=

# ── TREND BOT — Hyperliquid (Required for bot operation) ───
TREND_BOT_PRIVATE_KEY=
TREND_BOT_WALLET_ADDRESS=

# ── TELEGRAM (Optional) ───────────────────────────────────
# Leave empty to disable Telegram notifications and chat bot.
# Create a bot via @BotFather on Telegram to get these values.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── HEYGEN (Optional) ─────────────────────────────────────
# Leave empty to disable AI avatar video generation.
HEYGEN_API_KEY=

# ── STRIPE (Optional) ─────────────────────────────────────
# Leave empty to disable payment/revenue tracking dashboard.
STRIPE_SECRET_KEY=

# ── COMPOSIO / GOOGLE CALENDAR (Optional) ─────────────────
# Leave empty to disable calendar assistant integration.
COMPOSIO_API_KEY=

# ── BRAND ASSETS (Optional) ──────────────────────────────
# Base URL for brand logo assets (used by Canva designer agent)
BRAND_ASSET_URL=

# ── INFRASTRUCTURE (Auto-set by installer) ────────────────
INSTALL_DIR=/opt/tradingplatform
DASHBOARD_URL=http://localhost:3000
