# ============================================================
# NeuraLabs Command Center — Configuration
# Most settings are configured via the setup wizard in the browser.
# ============================================================

# ── COMMAND CENTER AUTH (Set by installer) ────────────────
CC_PASSWORD=
CC_SESSION_SECRET=

# ── BRANDING (Configured via setup wizard) ────────────────
COMPANY_NAME=
ASSISTANT_NAME=
TAGLINE=
PRIMARY_COLOR_HUE=264
PRIMARY_COLOR_SAT=65
PRIMARY_COLOR_LIT=49

# ── AI (Configured via setup wizard) ─────────────────────
ANTHROPIC_API_KEY=

# ── TELEGRAM (Configured via setup wizard) ────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── INTEGRATIONS (Configured via setup wizard) ───────────
HEYGEN_API_KEY=
STRIPE_SECRET_KEY=
COMPOSIO_API_KEY=
YOUTUBE_API_KEY=

# ── META / INSTAGRAM (Optional — for Ads Manager) ───────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# ── TRADING BOTS — Hyperliquid ───────────────────────────
# Private keys (NEVER share these!)
HL_PRIVATE_KEY_BOT1=
HL_PRIVATE_KEY_BOT5=

# Wallet addresses
HL_WALLET_ADDRESS_BOT1=
HL_WALLET_ADDRESS_BOT2=
HL_WALLET_ADDRESS_BOT3=
HL_WALLET_ADDRESS_BOT4=
HL_WALLET_ADDRESS_BOT5=

# ── BRAND ASSETS ─────────────────────────────────────────
BRAND_ASSET_URL=

# ── INFRASTRUCTURE (Auto-set by installer) ────────────────
INSTALL_DIR=/opt/commandcenter
DASHBOARD_URL=http://localhost:3004
