# Secrets
.env
!.env.example

# OAuth tokens
command-center/data/canva-oauth.json

# Runtime data
*/node_modules/
*/venv/
*/__pycache__/
*.pyc

# Logs
*.log
*/logs/*.log
command-center/data/cron.log
command-center/data/research-agent.log

# Generated images
command-center/data/generated-images/*
!command-center/data/generated-images/.gitkeep

# AI video uploads
command-center/data/ai-video-uploads/*
!command-center/data/ai-video-uploads/.gitkeep

# Video projects (user data)
command-center/data/video-projects/*
!command-center/data/video-projects/.gitkeep

# Nano Banana temp files
command-center/data/nb-*.json

# Media uploads
command-center/public/media/*
!command-center/public/media/.gitkeep

# Community manager runtime data (channels + archetype sets are customer-specific)
command-center/data/community/
command-center/data/social-media/

# Brand asset uploads (customers upload their own)
command-center/data/brand-assets/*/icon.png
command-center/data/brand-assets/*/logo.png

# Transcripts
command-center/data/transcripts/*
!command-center/data/transcripts/.gitkeep

# Lock files
.bot*.lock
.server.lock

# Build artifacts
command-center/dist/
command-center/.next/

# Package lock (customers install fresh)
command-center/package-lock.json

# Addon directories (installed separately)
trading-dashboard/

# OS
.DS_Store
Thumbs.db
